# ── MongoDB Atlas ─────────────────────────────────────────────
# Chỉ cần điền password — URI đã có sẵn trong config.py
# MONGO_PASSWORD=your_db_password_here
# MONGO_DB=tourism_db

# Nếu muốn override hoàn toàn URI (optional):
MONGO_URI=mongodb+srv://22050055_db_user:khang123@khang1402.e2kn7mt.mongodb.net/?appName=khang1402&retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_RANDOM_32_BYTES_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Services (face_service port 8001) ──────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT=10.0

# ── QR RSA Keys ───────────────────────────────────────────────
QR_PRIVATE_KEY_PATH=../ai-services/qr_generator/keys/private.pem
QR_PUBLIC_KEY_PATH=../ai-services/qr_generator/keys/public.pem

# ── ID Hash pepper (phải giống ai-services) ───────────────────
ID_HASH_PEPPER=tourism_id_pepper_v1_CHANGE_IN_PROD

# ── Nonce TTL ─────────────────────────────────────────────────
NONCE_TTL_HOURS=24

# ── CORS (thêm domain production nếu cần) ────────────────────
# CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
