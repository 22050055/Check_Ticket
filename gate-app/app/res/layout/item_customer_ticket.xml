<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    android:padding="16dp">

    <!-- ── Row 1: Loại vé + Badge trạng thái ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Ticket icon -->
        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🎫"
            android:textSize="20sp"
            android:gravity="center"
            android:background="@drawable/bg_accent_circle"/>

        <!-- Loại vé + Booking ID -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_ticket_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vé người lớn"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_booking_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#BK-001"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Còn hiệu lực"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_badge_active"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginVertical="12dp"/>

    <!-- ── Row 2: Thông tin ngày + giá ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Ngày hiệu lực -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIỆU LỰC TỪ"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_valid_from"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2025"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Ngày hết hạn -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HẾT HẠN"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_valid_until"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="31/12/2025"
                android:textColor="#FF6B6B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Giá -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIÁ VÉ"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150.000đ"
                android:textColor="@color/accent_blue"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Row 3: Nút tải QR + đăng ký mặt ── -->
    <!-- ── Row 3: Nút tải QR + đăng ký mặt + Huỷ ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"
        android:weightSum="100">

        <!-- Nút huỷ vé -->
        <TextView
            android:id="@+id/btn_cancel_ticket"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="25"
            android:text="✖ Hủy vé"
            android:textColor="#FF6B6B"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_input"
            android:layout_marginEnd="6dp"
            android:visibility="gone"/>

        <!-- Nút tải QR -->
        <TextView
            android:id="@+id/btn_download_qr"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="37.5"
            android:text="📥 QR Code"
            android:textColor="@color/navy_deep"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginEnd="6dp"/>

        <!-- Nút đăng ký mặt -->
        <TextView
            android:id="@+id/btn_enroll_face"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="37.5"
            android:text="🤳 Đăng ký Face"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_input"/>
    </LinearLayout>

    <!-- ── Row 4: Nút Đánh giá (chỉ hiện khi đã sử dụng) ── -->
    <TextView
        android:id="@+id/btn_review"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:text="⭐  Đánh giá dịch vụ"
        android:textColor="@color/navy_deep"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_btn_accent"
        android:visibility="gone"/>

</LinearLayout>
 