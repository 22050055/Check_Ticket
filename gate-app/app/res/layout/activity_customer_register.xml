<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_deep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="28dp"
        android:paddingTop="52dp"
        android:paddingBottom="40dp">

        <!-- Logo mark -->
        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_accent_circle"
            android:gravity="center"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏖"
                android:textSize="32sp"/>
        </LinearLayout>

        <!-- Headline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo Tài Khoản Khách Mới"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lịch sử vé và ảnh khuôn mặt sẽ được lưu trữ"
            android:textColor="@color/accent_blue"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"/>

        <!-- Form card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp">

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HỌ VÀ TÊN"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edit_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Nhập họ và tên"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp"/>

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Nhập email"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="16dp"/>

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edit_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Nhập mật khẩu"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="24dp"/>

            <!-- Register button -->
            <TextView
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="ĐĂNG KÝ"
                android:textColor="@color/navy_deep"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:background="@drawable/bg_btn_primary"/>
                
            <!-- Login Link -->
            <TextView
                android:id="@+id/tv_login"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Đã có tài khoản? QUAY LẠI ĐĂNG NHẬP"
                android:textColor="@color/accent_blue"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Version -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0 · Mua vé ngay trên điện thoại"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginTop="32dp"/>

    </LinearLayout>
</ScrollView>
 